# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Environments and secrets
.env
.venv/
venv/
ENV/

# Testing / tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# IDE / OS
.vscode/
.idea/
.DS_Store

# Runtime/log output
*.log
logs/

# Local market data and generated reports
data/raw/*
data/processed/*
data/cache/*
reports/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/cache/.gitkeep
!reports/.gitkeep
